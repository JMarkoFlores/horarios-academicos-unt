# PostgreSQL: credenciales y puerto expuesto del contenedor.
POSTGRES_CONTAINER_NAME=horarios_postgres
POSTGRES_PORT=5432
POSTGRES_DB=horarios_unt
POSTGRES_USER=unt_user
POSTGRES_PASSWORD=unt_pass123

# pgAdmin: acceso web para administrar PostgreSQL.
PGADMIN_CONTAINER_NAME=horarios_pgadmin
PGADMIN_PORT=5052
PGADMIN_DEFAULT_EMAIL=admin@localhost.com
PGADMIN_DEFAULT_PASSWORD=admin123

# Redis: nombre del contenedor, host interno y cache TTL.
REDIS_CONTAINER_NAME=horarios_redis
REDIS_PORT=6379
REDIS_HOST=redis
REDIS_TTL=300
REDIS_URL=redis://redis:6379

# Backend NestJS: variables de conexion, JWT y CORS/WebSockets.
BACKEND_CONTAINER_NAME=horarios_backend
BACKEND_PORT=3000
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=horarios_unt
DATABASE_USER=unt_user
DATABASE_PASSWORD=unt_pass123
JWT_SECRET=cambia-este-secreto-en-produccion
JWT_EXPIRACION=8h
NODE_ENV=production
PORT=3000
FRONTEND_URL=http://localhost:8080

# Cloudinary: almacenamiento externo de firmas de docentes.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Frontend/Nginx: nombre del contenedor y puerto publico del proxy.
FRONTEND_CONTAINER_NAME=horarios_frontend
FRONTEND_PORT=8080
