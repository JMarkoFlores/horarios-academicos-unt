{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testMatch": ["<rootDir>/test/integration/**/*.e2e-spec.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testEnvironment": "node",
  "setupFilesAfterEnv": ["<rootDir>/test/setup.ts"],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1",
    "^@common/(.*)$": "<rootDir>/src/common/$1",
    "^@auth/(.*)$": "<rootDir>/src/auth/$1",
    "^@cursos/(.*)$": "<rootDir>/src/cursos/$1",
    "^@docentes/(.*)$": "<rootDir>/src/docentes/$1",
    "^@grupos/(.*)$": "<rootDir>/src/grupos/$1",
    "^@horarios/(.*)$": "<rootDir>/src/horarios/$1",
    "^@disponibilidad/(.*)$": "<rootDir>/src/disponibilidad/$1",
    "^@ventanas/(.*)$": "<rootDir>/src/ventanas/$1",
    "^@dashboard/(.*)$": "<rootDir>/src/dashboard/$1",
    "^@reportes/(.*)$": "<rootDir>/src/reportes/$1",
    "^@notificaciones/(.*)$": "<rootDir>/src/notificaciones/$1"
  },
  "maxWorkers": 1,
  "testTimeout": 30000
}
